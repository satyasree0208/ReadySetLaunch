# ─────────────────────────────────────────────
#  ReadySetLaunch — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Supabase project URL (from Supabase → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for server use with RLS)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (NEVER expose this to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your app's public URL (used for Google OAuth redirect)
APP_URL=http://localhost:3000

# Backend port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
